# ============================================================================
#  Bingoo POS — Environment Template (PRODUCTION-ORIENTED)
# ----------------------------------------------------------------------------
#  Copy to .env and fill in real values:   cp .env.example .env
#  For LOCAL development, override values in your own .env (do NOT edit this
#  file with local/test values — keep it production-shaped).
# ============================================================================

# ─────────────────────────────  APP  ───────────────────────────────────────
APP_NAME="Bingoo POS"
APP_ENV=production
# Generate once after first deploy:  php artisan key:generate
APP_KEY=
# MUST stay false in production (true leaks stack traces / config).
APP_DEBUG=false
APP_URL=https://bingoopos.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ──────────────────────  DOMAINS / TENANCY  ────────────────────────────────
# CENTRAL_DOMAIN      → the marketing site + central admin (apex domain).
# TENANT_BASE_DOMAIN  → tenants live at  {tenant_code}.TENANT_BASE_DOMAIN
# BOTH must match your wildcard DNS + wildcard SSL certificate.
# e.g. tenant "acme" resolves to  acme.bingoopos.com
CENTRAL_DOMAIN=bingoopos.com
TENANT_BASE_DOMAIN=bingoopos.com

# ─────────────────  DATABASE — MASTER CONNECTION  ──────────────────────────
# The master DB holds tenants, plans, modules, subscriptions, invoices, etc.
# IMPORTANT: this DB user also CREATEs/DROPs tenant databases at provisioning
# time (see app/Services/Tenancy/TenantProvisioner.php), so it MUST have the
# CREATE DATABASE (and DROP) privilege.
DB_CONNECTION=master
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_saas_master
DB_USERNAME=pos_saas_user
DB_PASSWORD=

# ───────────────  DATABASE — TENANT PROVISIONING  ──────────────────────────
# Each tenant gets its own database (pos_tenant_{code}), created at runtime and
# connected to via this "tenant" connection (the database name is set per
# request, so it is intentionally left blank in config — do not set it here).
# This user needs ALL PRIVILEGES on the  pos_tenant_%  databases.
# Simplest setup: use the SAME user as the master connection, granted:
#   GRANT ALL PRIVILEGES ON `pos\_tenant\_%`.* TO 'pos_saas_user'@'%';
#   GRANT CREATE, DROP ON *.* TO 'pos_saas_user'@'%';   (for provisioning)
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_DB_USERNAME=pos_saas_user
TENANT_DB_PASSWORD=

# ────────────────────  CACHE / SESSION / QUEUE  ────────────────────────────
# database drivers work out of the box; switch to redis for higher scale.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave null so each tenant subdomain gets its own cookie scope.
SESSION_DOMAIN=null

CACHE_STORE=database
# No queued jobs ship today, so the database default is safe without a worker.
# Add `php artisan queue:work` once mail/notifications (PRD-5) are added.
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ──────────────────────────────  MAIL  ─────────────────────────────────────
# Transactional mail is not wired yet (PRD-5). Configure SMTP now so it is
# ready; until then nothing is sent.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=support@bingoopos.com
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────  STORAGE / FILES  ──────────────────────────────────
# "local" keeps uploads (e.g. payment proofs) on the server disk. Ensure
# storage/ and bootstrap/cache/ are writable; run `php artisan storage:link`.
FILESYSTEM_DISK=local

# ─────────────────────  SAAS CONTACT / BRAND  ──────────────────────────────
SAAS_SALES_EMAIL=sales@bingoopos.com
SAAS_SUPPORT_EMAIL=support@bingoopos.com
SAAS_WEBSITE_URL=https://bingoopos.com
SAAS_CONTACT_PHONE=
# Brand defaults live in config/saas.php; override here only if needed.
# SAAS_BRAND_NAME="Bingoo"
# SAAS_DEFAULT_TRIAL_DAYS=30
# SAAS_DEFAULT_CURRENCY=PKR

# ──────────────────────────  DEMO SAFETY  ──────────────────────────────────
# Public demo workspaces. NEVER use this password for a real tenant.
# Set SAAS_DEMOS_ENABLED=false on a pure production host with no public demos.
SAAS_DEMOS_ENABLED=true
SAAS_DEMO_DEFAULT_PASSWORD=demo1234
# Nightly demo reset time (24h HH:MM); requires OS cron (see DEPLOYMENT.md).
SAAS_DEMOS_RESET_DAILY_AT=04:00

# ────────────────────────────  LOGGING  ────────────────────────────────────
# Rotating daily logs in production (use stack/single for local debugging).
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ───────────────────  OPTIONAL EXTERNAL SERVICES  ──────────────────────────
# Redis (recommended for cache/session/queue at scale):
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# AWS S3 (only if you move file storage off the server disk):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
